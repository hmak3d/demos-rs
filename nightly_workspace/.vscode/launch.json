    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug unit tests in executable 'memoize_fn'",
            "cargo": {
                "args": [
                    "build",
                    "--bin=memoize_fn",
                    "--package=simple"
                ],
                "filter": {
                    "name": "memoize_fn",
                    "kind": "bin"
                }
            },
            "args": [],
            "osx": {
                "preLaunchTask": "Enable non-root debugging"
            },
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug unit tests in simple lib",
            "cargo": {
                "args": [
                    "test",
                    "--lib",
                    "--package=simple"
                ]
            },
            "args": [],
            "osx": {
                "preLaunchTask": "Enable non-root debugging"
            }
        }
    ]
}
